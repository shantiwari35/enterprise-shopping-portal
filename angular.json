{
	"$schema": "./node_modules/@angular/cli/lib/config/schema.json",
	"version": 1,
	"newProjectRoot": "projects",
	"projects": {
		"host-shell": {
			"projectType": "application",
			"schematics": {
				"@schematics/angular:component": {
					"style": "scss"
				}
			},
			"root": "projects/host-shell",
			"sourceRoot": "projects/host-shell/src",
			"prefix": "app",
			"architect": {
				"build": {
					"builder": "ngx-build-plus:browser",
					"options": {
						"outputPath": "dist/host-shell",
						"index": "projects/host-shell/src/index.html",
						"main": "projects/host-shell/src/main.ts",
						"polyfills": "projects/host-shell/src/polyfills.ts",
						"tsConfig": "projects/host-shell/tsconfig.app.json",
						"inlineStyleLanguage": "scss",
						"assets": [
							"projects/host-shell/src/favicon.ico",
							"projects/host-shell/src/assets"
						],
						"styles": [
							"projects/host-shell/src/styles.scss"
						],
						"scripts": [],
						"extraWebpackConfig": "projects/host-shell/webpack.config.js",
						"commonChunk": false
					},
					"configurations": {
						"production": {
							"budgets": [
								{
									"type": "initial",
									"maximumWarning": "500kb",
									"maximumError": "1mb"
								},
								{
									"type": "anyComponentStyle",
									"maximumWarning": "2kb",
									"maximumError": "4kb"
								}
							],
							"fileReplacements": [
								{
									"replace": "projects/host-shell/src/environments/environment.ts",
									"with": "projects/host-shell/src/environments/environment.prod.ts"
								}
							],
							"outputHashing": "all",
							"extraWebpackConfig": "projects/host-shell/webpack.prod.config.js"
						},
						"development": {
							"buildOptimizer": false,
							"optimization": false,
							"vendorChunk": true,
							"extractLicenses": false,
							"sourceMap": true,
							"namedChunks": true
						}
					},
					"defaultConfiguration": "production"
				},
				"serve": {
					"builder": "ngx-build-plus:dev-server",
					"configurations": {
						"production": {
							"browserTarget": "host-shell:build:production",
							"extraWebpackConfig": "projects/host-shell/webpack.prod.config.js"
						},
						"development": {
							"browserTarget": "host-shell:build:development"
						}
					},
					"defaultConfiguration": "development",
					"options": {
						"port": 4200,
						"publicHost": "http://localhost:4200",
						"extraWebpackConfig": "projects/host-shell/webpack.config.js"
					}
				},
				"extract-i18n": {
					"builder": "ngx-build-plus:extract-i18n",
					"options": {
						"browserTarget": "host-shell:build",
						"extraWebpackConfig": "projects/host-shell/webpack.config.js"
					}
				},
				"test": {
					"builder": "@angular-devkit/build-angular:karma",
					"options": {
						"main": "projects/host-shell/src/test.ts",
						"polyfills": "projects/host-shell/src/polyfills.ts",
						"tsConfig": "projects/host-shell/tsconfig.spec.json",
						"karmaConfig": "projects/host-shell/karma.conf.js",
						"inlineStyleLanguage": "scss",
						"assets": [
							"projects/host-shell/src/favicon.ico",
							"projects/host-shell/src/assets"
						],
						"styles": [
							"projects/host-shell/src/styles.scss"
						],
						"scripts": []
					}
				}
			}
		},
